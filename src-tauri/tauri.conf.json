{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ABC管理系统",
  "version": "1.0.0",
  "identifier": "com.abc.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "https://abc.k84.org"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ABC管理系统",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "maximized": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": "default-src 'self' https://abc.k84.org https://abcapi.k84.org; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://abc.k84.org; style-src 'self' 'unsafe-inline' https://abc.k84.org; img-src 'self' data: https://abc.k84.org https://abcapi.k84.org; connect-src 'self' https://abc.k84.org https://abcapi.k84.org wss://abcapi.k84.org; font-src 'self' https://abc.k84.org",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis", "msi"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "displayLanguageSelector": true,
        "languages": ["SimpChinese", "English"],
        "installMode": "both"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg5MzI4OTIwNkJBOENEOUUKUldTZXphaHJJSWt5aVJNUVRicWFSSzV4QWJHM1VpS2M0RGNxL05IbFpoUlZUOWpmL01YK1M3OXUK",
      "endpoints": [
        "https://github.com/DanielChung520/aibox/releases/latest/download/latest.json"
      ],
      "dialog": true
    }
  }
}
